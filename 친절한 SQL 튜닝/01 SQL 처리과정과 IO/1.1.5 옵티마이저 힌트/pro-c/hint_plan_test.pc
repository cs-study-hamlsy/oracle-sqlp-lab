#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "../../../../common/include/oracle_db_config.h"

EXEC SQL INCLUDE SQLCA;

/*
 * 1.1.5 옵티마이저 힌트
 *
 * 이 예제는 쉬운 고객/주문 데이터로 아래를 비교한다.
 *
 * 1. CUSTOMER_CONTACTS / CUSTOMER_ORDERS 생성
 * 2. 인덱스 생성과 통계정보 수집
 * 3. 단일 테이블 SQL에서 INDEX / FULL 힌트 비교
 * 4. 조인 SQL에서 LEADING / USE_NL 힌트 비교
 * 5. DBMS_XPLAN.DISPLAY 결과 출력
 */

static const char *read_env_or_default(const char *name, const char *default_value)
{
    const char *value = getenv(name);

    if (value == NULL || value[0] == '\0') {
        return default_value;
    }

    return value;
}

static void copy_to_varchar(VARCHAR *target, const char *source, size_t max_len)
{
    size_t length = strlen(source);

    if (length > max_len) {
        length = max_len;
    }

    memset(target->arr, 0, max_len + 1);
    memcpy(target->arr, source, length);
    target->len = (unsigned short) length;
}

static void print_sql_error(const char *message)
{
    fprintf(stderr, "%s\n", message);
    fprintf(stderr, "SQLCODE: %ld\n", sqlca.sqlcode);
    fprintf(stderr, "SQLERRM: %.*s\n", sqlca.sqlerrm.sqlerrml, sqlca.sqlerrm.sqlerrmc);
}

static int connect_oracle(void)
{
    const char *env_user = read_env_or_default(ORACLE_ENV_USER, NULL);
    const char *env_password = read_env_or_default(ORACLE_ENV_PASSWORD, NULL);
    const char *env_connect_string = read_env_or_default(
        ORACLE_ENV_CONNECT_STRING,
        ORACLE_DEFAULT_CONNECT_STRING
    );

    EXEC SQL BEGIN DECLARE SECTION;
        VARCHAR username[ORACLE_USER_MAX_LEN + 1];
        VARCHAR password[ORACLE_PASSWORD_MAX_LEN + 1];
        VARCHAR connect_string[ORACLE_CONNECT_STRING_MAX_LEN + 1];
    EXEC SQL END DECLARE SECTION;

    if (env_user == NULL || env_password == NULL) {
        fprintf(stderr, "Set ORACLE_USER and ORACLE_PASSWORD before running.\n");
        return 1;
    }

    copy_to_varchar(&username, env_user, ORACLE_USER_MAX_LEN);
    copy_to_varchar(&password, env_password, ORACLE_PASSWORD_MAX_LEN);
    copy_to_varchar(&connect_string, env_connect_string, ORACLE_CONNECT_STRING_MAX_LEN);

    EXEC SQL CONNECT :username IDENTIFIED BY :password USING :connect_string;
    if (sqlca.sqlcode != 0) {
        print_sql_error("Oracle connect failed.");
        return 1;
    }

    printf("Connected to Oracle with PRO-C: %s\n", env_connect_string);
    return 0;
}

static int setup_objects(void)
{
    EXEC SQL EXECUTE IMMEDIATE
        "BEGIN "
        "    EXECUTE IMMEDIATE 'DROP TABLE customer_orders PURGE'; "
        "EXCEPTION "
        "    WHEN OTHERS THEN "
        "        IF SQLCODE != -942 THEN RAISE; END IF; "
        "END;";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to reset CUSTOMER_ORDERS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "BEGIN "
        "    EXECUTE IMMEDIATE 'DROP TABLE customer_contacts PURGE'; "
        "EXCEPTION "
        "    WHEN OTHERS THEN "
        "        IF SQLCODE != -942 THEN RAISE; END IF; "
        "END;";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to reset CUSTOMER_CONTACTS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "CREATE TABLE customer_contacts ("
        "    customer_id number not null, "
        "    customer_name varchar2(100) not null, "
        "    phone_number varchar2(30) not null, "
        "    address varchar2(200) not null, "
        "    city varchar2(40) not null, "
        "    customer_status varchar2(20) not null, "
        "    signup_at date not null, "
        "    constraint pk_customer_contacts primary key (customer_id)"
        ")";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to create CUSTOMER_CONTACTS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "CREATE TABLE customer_orders ("
        "    order_id number not null, "
        "    customer_id number not null, "
        "    order_amount number(10,2) not null, "
        "    order_status varchar2(20) not null, "
        "    order_at date not null, "
        "    constraint pk_customer_orders primary key (order_id), "
        "    constraint fk_customer_orders_customer "
        "        foreign key (customer_id) references customer_contacts(customer_id)"
        ")";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to create CUSTOMER_ORDERS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "INSERT INTO customer_contacts "
        "SELECT "
        "    level, "
        "    '고객' || TO_CHAR(level, 'FM000000'), "
        "    '010-' || LPAD(MOD(level, 10000), 4, '0') || '-' || LPAD(MOD(level * 7, 10000), 4, '0'), "
        "    '서울시 샘플로 ' || MOD(level, 500) || '번지', "
        "    CASE MOD(level, 5) "
        "        WHEN 0 THEN 'SEOUL' "
        "        WHEN 1 THEN 'BUSAN' "
        "        WHEN 2 THEN 'INCHEON' "
        "        WHEN 3 THEN 'DAEGU' "
        "        ELSE 'GWANGJU' "
        "    END, "
        "    CASE "
        "        WHEN MOD(level, 20) = 0 THEN 'VIP' "
        "        WHEN MOD(level, 3) = 0 THEN 'INACTIVE' "
        "        ELSE 'ACTIVE' "
        "    END, "
        "    DATE '2024-01-01' + MOD(level, 450) "
        "FROM dual CONNECT BY level <= 20000";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to insert CUSTOMER_CONTACTS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "INSERT INTO customer_orders "
        "SELECT "
        "    level, "
        "    MOD(level, 20000) + 1, "
        "    MOD(level * 37, 500000) / 10 + 10, "
        "    CASE MOD(level, 4) "
        "        WHEN 0 THEN 'PAID' "
        "        WHEN 1 THEN 'READY' "
        "        WHEN 2 THEN 'CANCEL' "
        "        ELSE 'DELIVERY' "
        "    END, "
        "    DATE '2025-01-01' + MOD(level, 120) "
        "FROM dual CONNECT BY level <= 120000";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to insert CUSTOMER_ORDERS.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "CREATE INDEX idx_customer_status_signup "
        "ON customer_contacts(customer_status, signup_at)";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to create IDX_CUSTOMER_STATUS_SIGNUP.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "CREATE INDEX idx_customer_city_signup "
        "ON customer_contacts(city, signup_at)";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to create IDX_CUSTOMER_CITY_SIGNUP.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "CREATE INDEX idx_orders_customer_date "
        "ON customer_orders(customer_id, order_at)";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to create IDX_ORDERS_CUSTOMER_DATE.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE
        "BEGIN "
        "    dbms_stats.gather_table_stats(user, 'CUSTOMER_CONTACTS', cascade => TRUE); "
        "    dbms_stats.gather_table_stats(user, 'CUSTOMER_ORDERS', cascade => TRUE); "
        "END;";
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to gather table stats.");
        return 1;
    }

    printf("실습 테이블과 인덱스 준비 완료\n");
    return 0;
}

static int print_plan_rows(const char *statement_id)
{
    EXEC SQL BEGIN DECLARE SECTION;
        VARCHAR plan_line[4000];
        char stmt_id[64];
    EXEC SQL END DECLARE SECTION;

    strcpy(stmt_id, statement_id);

    EXEC SQL DECLARE plan_cursor CURSOR FOR
        SELECT plan_table_output
        FROM TABLE(dbms_xplan.display(NULL, :stmt_id, 'BASIC +COST +BYTES +PREDICATE +ALIAS'));

    EXEC SQL OPEN plan_cursor;
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to open plan cursor.");
        return 1;
    }

    while (1) {
        EXEC SQL FETCH plan_cursor INTO :plan_line;
        if (sqlca.sqlcode == 1403) {
            break;
        }
        if (sqlca.sqlcode != 0) {
            print_sql_error("Failed to fetch plan rows.");
            EXEC SQL CLOSE plan_cursor;
            return 1;
        }

        plan_line.arr[plan_line.len] = '\0';
        printf("%s\n", (char *) plan_line.arr);
    }

    EXEC SQL CLOSE plan_cursor;
    return 0;
}

static int explain_case(const char *label, const char *statement_id, const char *query)
{
    EXEC SQL BEGIN DECLARE SECTION;
        VARCHAR stmt_id[64];
        VARCHAR explain_sql[4096];
    EXEC SQL END DECLARE SECTION;

    char buffer[4096];

    snprintf(
        buffer,
        sizeof(buffer),
        "EXPLAIN PLAN SET statement_id = '%s' FOR %s",
        statement_id,
        query
    );

    copy_to_varchar(&stmt_id, statement_id, 63);
    copy_to_varchar(&explain_sql, buffer, 4095);

    EXEC SQL DELETE FROM plan_table WHERE statement_id = :stmt_id;
    if (sqlca.sqlcode != 0 && sqlca.sqlcode != 1403) {
        print_sql_error("Failed to cleanup previous plan rows.");
        return 1;
    }

    EXEC SQL EXECUTE IMMEDIATE :explain_sql;
    if (sqlca.sqlcode != 0) {
        print_sql_error("Failed to execute explain plan.");
        return 1;
    }

    printf("\n=== %s ===\n", label);
    printf("%s\n\n", query);

    return print_plan_rows(statement_id);
}

int main(void)
{
    if (connect_oracle() != 0) {
        return 1;
    }

    if (setup_objects() != 0) {
        EXEC SQL ROLLBACK RELEASE;
        return 1;
    }

    if (explain_case(
            "기본 SQL",
            "HINT_BASE_QUERY",
            "SELECT c.customer_name, c.phone_number, c.address, c.signup_at "
            "FROM customer_contacts c "
            "WHERE c.customer_status = 'ACTIVE' "
            "AND c.signup_at >= DATE '2025-01-01' "
            "AND c.signup_at < DATE '2025-02-01'"
        ) != 0 ||
        explain_case(
            "INDEX 힌트 SQL",
            "HINT_INDEX_QUERY",
            "SELECT /*+ index(c idx_customer_status_signup) */ "
            "c.customer_name, c.phone_number, c.address, c.signup_at "
            "FROM customer_contacts c "
            "WHERE c.customer_status = 'ACTIVE' "
            "AND c.signup_at >= DATE '2025-01-01' "
            "AND c.signup_at < DATE '2025-02-01'"
        ) != 0 ||
        explain_case(
            "FULL 힌트 SQL",
            "HINT_FULL_QUERY",
            "SELECT /*+ full(c) */ "
            "c.customer_name, c.phone_number, c.address, c.signup_at "
            "FROM customer_contacts c "
            "WHERE c.customer_status = 'ACTIVE' "
            "AND c.signup_at >= DATE '2025-01-01' "
            "AND c.signup_at < DATE '2025-02-01'"
        ) != 0 ||
        explain_case(
            "조인 힌트 SQL",
            "HINT_JOIN_QUERY",
            "SELECT /*+ leading(c o) use_nl(o) index(c idx_customer_status_signup) index(o idx_orders_customer_date) */ "
            "c.customer_name, c.phone_number, o.order_amount, o.order_at "
            "FROM customer_contacts c "
            "JOIN customer_orders o ON o.customer_id = c.customer_id "
            "WHERE c.customer_status = 'VIP' "
            "AND c.signup_at >= DATE '2025-01-01' "
            "AND o.order_at >= DATE '2025-02-01'"
        ) != 0) {
        EXEC SQL ROLLBACK RELEASE;
        return 1;
    }

    printf("\n비교 포인트:\n");
    printf("- INDEX 힌트가 INDEX RANGE SCAN으로 반영되는가\n");
    printf("- FULL 힌트가 TABLE ACCESS FULL로 반영되는가\n");
    printf("- 조인에서 CUSTOMER_CONTACTS를 먼저 읽는가\n");
    printf("- NESTED LOOPS와 인덱스 접근이 함께 나타나는가\n");

    EXEC SQL COMMIT WORK RELEASE;
    return 0;
}
